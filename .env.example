# HiveMind — Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your keys.
#
# Strategy: distribute load across Groq + OpenRouter to avoid hammering
# Google AI Studio accounts. Gemini used only for ORCHESTRATOR (few calls).
# Groq (3 keys) + OpenRouter (3 keys) handle all ANALYST + WORKER traffic.
#
# Key rotation: multiple keys on one line, comma-separated. HiveMind picks
# the least-used available key per request. On 429, marks that key rate-limited
# for 60s and rotates to the next.
#
# Model class roles:
#   orchestrator  — root planning, decomposition, final audit (few calls, best model)
#   analyst       — file-owner agents, mid-depth reasoning, audit pass (medium)
#   worker        — function writers, leaf execution, high throughput (many calls)
#   fast          — simple formatting, short merges (optional, lightest)
#
# Escalation: if a class is exhausted, HiveMind escalates automatically.
#   fast → worker → analyst → orchestrator
# ─────────────────────────────────────────────────────────────────────────────


# ── ORCHESTRATOR ──────────────────────────────────────────────────────────────
# Reserved for: root classify, architectural planning, final cross-file audit.
# Called maybe 2-4 times per complex task — safe to use best model here.
# Gemini 2.5 Pro on a SINGLE key is fine since orchestrator calls are rare.

CLASS_GEMINI_PRO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CLASS_GEMINI_PRO_MODEL=gemini-2.5-pro
CLASS_GEMINI_PRO_KEYS=AIza_your_key_here
CLASS_GEMINI_PRO_CLASS=orchestrator

# Fallback orchestrator if Gemini is rate-limited:
# OpenRouter deepseek-r1 free — strong reasoning, no credits needed
CLASS_OR_ORC_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_ORC_MODEL=deepseek/deepseek-r1:free
CLASS_OR_ORC_KEYS=sk-or-key-1-here
CLASS_OR_ORC_CLASS=orchestrator


# ── ANALYST ───────────────────────────────────────────────────────────────────
# Reserved for: file-owner agents, per-file audit/merge, structured planning.
# Medium call volume — spread across Groq key 1 + OpenRouter key 2.

CLASS_GROQ_ANALYST_BASE_URL=https://api.groq.com/openai/v1
CLASS_GROQ_ANALYST_MODEL=llama-3.3-70b-versatile
CLASS_GROQ_ANALYST_KEYS=gsk_key_1_here,gsk_key_2_here
CLASS_GROQ_ANALYST_CLASS=analyst

CLASS_OR_ANALYST_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_ANALYST_MODEL=meta-llama/llama-3.3-70b-instruct:free
CLASS_OR_ANALYST_KEYS=sk-or-key-2-here,sk-or-key-3-here
CLASS_OR_ANALYST_CLASS=analyst


# ── WORKER ────────────────────────────────────────────────────────────────────
# High throughput — function writers, leaf tasks, bulk execution.
# Uses ALL remaining keys: Groq key 3 + remaining OpenRouter keys.
# Gemini flash-lite intentionally NOT used here to protect your Google accounts.

CLASS_GROQ_WORKER_BASE_URL=https://api.groq.com/openai/v1
CLASS_GROQ_WORKER_MODEL=llama-3.1-70b-versatile
CLASS_GROQ_WORKER_KEYS=gsk_key_3_here
CLASS_GROQ_WORKER_CLASS=worker

# OpenRouter free worker models — pick whichever is least rate-limited:
# Options: meta-llama/llama-3.1-8b-instruct:free
#          mistralai/mistral-7b-instruct:free
#          qwen/qwen-2.5-7b-instruct:free
CLASS_OR_WORKER_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_WORKER_MODEL=meta-llama/llama-3.1-8b-instruct:free
CLASS_OR_WORKER_KEYS=sk-or-key-1-here,sk-or-key-2-here,sk-or-key-3-here
CLASS_OR_WORKER_CLASS=worker


# ── FAST (optional) ───────────────────────────────────────────────────────────
# Smallest model for formatting, simple merges, short summaries.
# If not configured, falls back to WORKER automatically.

# CLASS_GROQ_FAST_BASE_URL=https://api.groq.com/openai/v1
# CLASS_GROQ_FAST_MODEL=llama-3.1-8b-instant
# CLASS_GROQ_FAST_KEYS=gsk_key_1_here,gsk_key_2_here,gsk_key_3_here
# CLASS_GROQ_FAST_CLASS=fast


# ── Key budget summary ────────────────────────────────────────────────────────
# Groq free tier:  ~14,400 tokens/min per key, 30 req/min per key
#   3 keys × 30 req/min = 90 req/min combined
# OpenRouter free: varies by model, typically 20 req/min per key
#   3 keys × 20 req/min = 60 req/min combined
# Gemini AI Studio: 1,500 req/day, 15 req/min — used only for orchestrator


# ── Legacy PROVIDER_* (still supported, treated as worker) ───────────────────
# PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_MODEL=llama3
# PROVIDER_OLLAMA_KEYS=ollama
