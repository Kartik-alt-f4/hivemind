# HiveMind — Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#
# Model class system — assign each provider a role:
#   CLASS_<NAME>_CLASS = orchestrator | analyst | worker | fast
#
#   orchestrator  — root planning, task decomposition, final merge
#                   use your best available free-tier model here
#   analyst       — mid-depth reasoning, architecture, research
#   worker        — leaf execution: coding, writing, extraction
#   fast          — simple formatting, short merges (optional)
#
# Fallback: if a class is exhausted or not configured, HiveMind escalates
# automatically (fast → worker → analyst → orchestrator).
#
# Legacy PROVIDER_* format still works — defaults to "worker" class.
# ─────────────────────────────────────────────────────────────────────────────


# ── ORCHESTRATOR class ────────────────────────────────────────────────────────
# Best free-tier options: gemini-2.5-pro, llama-3.3-70b (groq), deepseek-r1

# Google AI Studio — gemini-2.5-pro (free tier, strong reasoning)
# Get key: https://aistudio.google.com/app/apikey
# CLASS_GEMINI_PRO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# CLASS_GEMINI_PRO_MODEL=gemini-2.5-pro
# CLASS_GEMINI_PRO_KEYS=AIza_key_here
# CLASS_GEMINI_PRO_CLASS=orchestrator

# Groq — llama-3.3-70b (fast, high quality, generous free tier)
# Get key: https://console.groq.com/keys
# CLASS_GROQ_70B_BASE_URL=https://api.groq.com/openai/v1
# CLASS_GROQ_70B_MODEL=llama-3.3-70b-versatile
# CLASS_GROQ_70B_KEYS=gsk_key_here
# CLASS_GROQ_70B_CLASS=orchestrator

# OpenRouter — deepseek-r1 free (strong reasoning, no credits needed)
# CLASS_OR_ORCHESTRATOR_BASE_URL=https://openrouter.ai/api/v1
# CLASS_OR_ORCHESTRATOR_MODEL=deepseek/deepseek-r1:free
# CLASS_OR_ORCHESTRATOR_KEYS=sk-or-key-here
# CLASS_OR_ORCHESTRATOR_CLASS=orchestrator


# ── ANALYST class ─────────────────────────────────────────────────────────────
# Mid-weight reasoning: architecture, analysis, structured planning

# Groq — llama-3.1-70b or gemini-2.0-flash
# CLASS_GROQ_ANALYST_BASE_URL=https://api.groq.com/openai/v1
# CLASS_GROQ_ANALYST_MODEL=llama-3.1-70b-versatile
# CLASS_GROQ_ANALYST_KEYS=gsk_key_here
# CLASS_GROQ_ANALYST_CLASS=analyst

# CLASS_GEMINI_FLASH_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# CLASS_GEMINI_FLASH_MODEL=gemini-2.0-flash
# CLASS_GEMINI_FLASH_KEYS=AIza_key_here
# CLASS_GEMINI_FLASH_CLASS=analyst


# ── WORKER class ──────────────────────────────────────────────────────────────
# Light execution: coding, writing, extraction — high throughput needed

# Google AI Studio — flash-lite is fast and free with many keys
# Get key: https://aistudio.google.com/app/apikey
# Free tier: 1,500 req/day per key — add multiple keys to scale
CLASS_GEMINI_WORKER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CLASS_GEMINI_WORKER_MODEL=gemini-2.0-flash-lite
CLASS_GEMINI_WORKER_KEYS=AIza_key1_here,AIza_key2_here,AIza_key3_here
CLASS_GEMINI_WORKER_CLASS=worker

# Groq — 8b instant for ultra-low latency worker tasks
# CLASS_GROQ_WORKER_BASE_URL=https://api.groq.com/openai/v1
# CLASS_GROQ_WORKER_MODEL=llama-3.1-8b-instant
# CLASS_GROQ_WORKER_KEYS=gsk_key1,gsk_key2
# CLASS_GROQ_WORKER_CLASS=worker

# OpenRouter free models for worker tasks
# CLASS_OR_WORKER_BASE_URL=https://openrouter.ai/api/v1
# CLASS_OR_WORKER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# CLASS_OR_WORKER_KEYS=sk-or-key-here
# CLASS_OR_WORKER_CLASS=worker


# ── FAST class (optional) ─────────────────────────────────────────────────────
# Smallest/fastest — simple merges, short formatting, echo tasks

# CLASS_GEMINI_FAST_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# CLASS_GEMINI_FAST_MODEL=gemini-2.0-flash-lite
# CLASS_GEMINI_FAST_KEYS=AIza_key1_here,AIza_key2_here
# CLASS_GEMINI_FAST_CLASS=fast


# ── Legacy PROVIDER_* format (still supported → treated as "worker") ──────────
# PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_MODEL=llama3
# PROVIDER_OLLAMA_KEYS=ollama

# PROVIDER_TOGETHER_BASE_URL=https://api.together.xyz/v1
# PROVIDER_TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# PROVIDER_TOGETHER_KEYS=together_key1


# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_PARALLEL_AGENTS=8        # Max concurrent LLM calls at once
