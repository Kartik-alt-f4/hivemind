# HiveMind — Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your keys.
#
# Free tier limits (June 2026):
#
#   Groq         — 30 RPM, 1,000 RPD (heavy models) / 14,400 RPD (light models)
#   OpenRouter   — 20 RPM, 1,000 RPD (requires $10 lifetime spend, else 50 RPD)
#   Gemini       — 15 RPM, 1,000 RPD (flash-lite) / 10 RPM, 250 RPD (flash)
#                  NOTE: gemini-2.5-pro is PAID ONLY as of April 2026
#                  NOTE: enabling billing removes ALL free tier quotas
#
# Groq model changes (June 17, 2026 deprecations):
#   llama-3.3-70b-versatile → openai/gpt-oss-120b  (heavy, 1,000 RPD)
#   llama-3.1-8b-instant    → openai/gpt-oss-20b   (light, 14,400 RPD)
#
# Weights control dispatch probability: weight / (calls + 1)
# Higher weight = more calls routed here. Set based on RPD capacity.
# Within a provider, keys rotate by least-call-count automatically.
# On 429: key marked rate-limited for 60s, next key picked immediately.
# ─────────────────────────────────────────────────────────────────────────────


# ── ORCHESTRATOR ──────────────────────────────────────────────────────────────
# ~2-4 calls per complex task. Quality over throughput.
# deepseek-r1 free on OpenRouter is the best free orchestrator available.

CLASS_OR_ORC_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_ORC_MODEL=deepseek/deepseek-r1:free
CLASS_OR_ORC_KEYS=sk-or-key-1-here
CLASS_OR_ORC_CLASS=orchestrator
CLASS_OR_ORC_WEIGHT=3

# Gemini flash as fallback orchestrator (NOT 2.5-pro — that's paid)
CLASS_GEMINI_ORC_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CLASS_GEMINI_ORC_MODEL=gemini-2.0-flash
CLASS_GEMINI_ORC_KEYS=AIza_key_here
CLASS_GEMINI_ORC_CLASS=orchestrator
CLASS_GEMINI_ORC_WEIGHT=1


# ── ANALYST ───────────────────────────────────────────────────────────────────
# File-owner agents, mid-depth reasoning, per-file audit.
# ~5-10 calls per complex task. Balance quality + throughput.
#
# RPD budget: Groq 1,000/key × 2 keys = 2,000/day
#             OpenRouter 1,000/key × 2 keys = 2,000/day
# Weight 3:2 → Groq gets ~60% of analyst calls

CLASS_GROQ_ANALYST_BASE_URL=https://api.groq.com/openai/v1
CLASS_GROQ_ANALYST_MODEL=openai/gpt-oss-120b
CLASS_GROQ_ANALYST_KEYS=gsk_key_1_here,gsk_key_2_here
CLASS_GROQ_ANALYST_CLASS=analyst
CLASS_GROQ_ANALYST_WEIGHT=3

CLASS_OR_ANALYST_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_ANALYST_MODEL=meta-llama/llama-3.3-70b-instruct:free
CLASS_OR_ANALYST_KEYS=sk-or-key-2-here,sk-or-key-3-here
CLASS_OR_ANALYST_CLASS=analyst
CLASS_OR_ANALYST_WEIGHT=2


# ── WORKER ────────────────────────────────────────────────────────────────────
# Function writers, leaf execution. Highest call volume.
# Use light models with generous daily limits.
#
# RPD budget: Groq gpt-oss-20b = 14,400/day (by far the best free limit)
#             OpenRouter 8b    = 1,000/day × 3 keys = 3,000/day
#             Gemini flash-lite = 1,000/day (use sparingly)
# Weight 5:2:1 → Groq handles bulk, OR is secondary, Gemini is last resort

CLASS_GROQ_WORKER_BASE_URL=https://api.groq.com/openai/v1
CLASS_GROQ_WORKER_MODEL=openai/gpt-oss-20b
CLASS_GROQ_WORKER_KEYS=gsk_key_3_here
CLASS_GROQ_WORKER_CLASS=worker
CLASS_GROQ_WORKER_WEIGHT=5

CLASS_OR_WORKER_BASE_URL=https://openrouter.ai/api/v1
CLASS_OR_WORKER_MODEL=meta-llama/llama-3.1-8b-instruct:free
CLASS_OR_WORKER_KEYS=sk-or-key-1-here,sk-or-key-2-here,sk-or-key-3-here
CLASS_OR_WORKER_CLASS=worker
CLASS_OR_WORKER_WEIGHT=2

# Gemini flash-lite: good TPM (250k), but protect daily quota
# Add only if you have multiple Google accounts / projects
CLASS_GEMINI_WORKER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CLASS_GEMINI_WORKER_MODEL=gemini-2.0-flash-lite
CLASS_GEMINI_WORKER_KEYS=AIza_key_here
CLASS_GEMINI_WORKER_CLASS=worker
CLASS_GEMINI_WORKER_WEIGHT=1


# ── FAST (optional) ───────────────────────────────────────────────────────────
# Lightest/fastest for simple formatting, short merges.
# If not set, falls back to WORKER automatically.

# CLASS_GROQ_FAST_BASE_URL=https://api.groq.com/openai/v1
# CLASS_GROQ_FAST_MODEL=openai/gpt-oss-20b
# CLASS_GROQ_FAST_KEYS=gsk_key_1_here,gsk_key_2_here,gsk_key_3_here
# CLASS_GROQ_FAST_CLASS=fast
# CLASS_GROQ_FAST_WEIGHT=3


# ── Daily capacity summary ────────────────────────────────────────────────────
# ORCHESTRATOR: ~3,000 RPD combined (rarely hits this)
# ANALYST:      ~4,000 RPD combined (Groq 2k + OR 2k)
# WORKER:       ~18,400 RPD combined (Groq 14.4k + OR 3k + Gemini 1k)
# A complex 10-agent task uses roughly 15-25 LLM calls total.
# This config supports ~700 complex tasks/day before hitting limits.


# ── Legacy PROVIDER_* (still supported, treated as worker class) ──────────────
# PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_MODEL=llama3
# PROVIDER_OLLAMA_KEYS=ollama
# PROVIDER_OLLAMA_WEIGHT=4   # local = unlimited, give it high weight
