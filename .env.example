# HiveMind Agent Cluster - Provider Config
# Supports any OpenAI-compatible API (Gemini, Groq, Together, Ollama, OpenAI, etc.)

# --- PROVIDER POOLS ---
# Format: PROVIDER_<NAME>_BASE_URL, PROVIDER_<NAME>_KEYS (comma-separated), PROVIDER_<NAME>_MODEL

# Google Gemini (via OpenAI-compat endpoint)
PROVIDER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
PROVIDER_GEMINI_MODEL=gemini-2.0-flash-lite
PROVIDER_GEMINI_KEYS=AIza_key1_here,AIza_key2_here,AIza_key3_here

# Groq (optional)
# PROVIDER_GROQ_BASE_URL=https://api.groq.com/openai/v1
# PROVIDER_GROQ_MODEL=llama3-8b-8192
# PROVIDER_GROQ_KEYS=gsk_key1,gsk_key2

# Together AI (optional)
# PROVIDER_TOGETHER_BASE_URL=https://api.together.xyz/v1
# PROVIDER_TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# PROVIDER_TOGETHER_KEYS=together_key1

# OpenAI (optional)
# PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
# PROVIDER_OPENAI_MODEL=gpt-4o-mini
# PROVIDER_OPENAI_KEYS=sk-key1

# Local Ollama (optional, no key needed)
# PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_MODEL=llama3
# PROVIDER_OLLAMA_KEYS=ollama

# --- TREE SETTINGS ---
MAX_DEPTH=6                  # Hard cap on recursion depth
MAX_PARALLEL_AGENTS=8        # Max concurrent agents at one time
MIN_COMPLEXITY_TO_SPLIT=3    # 1-10 score; below this, agent solves directly
