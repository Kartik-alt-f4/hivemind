# HiveMind — Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Any block you leave commented out will be ignored.
# Add as many providers as you want — the cluster rotates between them.
#
# Format per provider:
#   PROVIDER_<NAME>_BASE_URL  — OpenAI-compatible endpoint
#   PROVIDER_<NAME>_MODEL     — model ID for this provider
#   PROVIDER_<NAME>_KEYS      — comma-separated API keys (pool-rotated)
# ─────────────────────────────────────────────────────────────────────────────


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get key   : https://aistudio.google.com/app/apikey
# Free tier : 1,500 req/day · 15 req/min per key — add multiple keys to scale
# Best model: gemini-3.1-flash-lite (fastest, cheapest on free tier)
# Good for  : high-throughput agentic workloads, generous free quota
PROVIDER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
PROVIDER_GEMINI_MODEL=gemini-3.1-flash-lite
PROVIDER_GEMINI_KEYS=AIza_key1_here,AIza_key2_here,AIza_key3_here


# ── Groq ──────────────────────────────────────────────────────────────────────
# Get key   : https://console.groq.com/keys
# Free tier : 14,400 req/day · very fast inference (hardware accelerated)
# Best model: llama-3.1-8b-instant (lowest latency), llama-3.3-70b-versatile (quality)
# Good for  : ultra-low latency, fast iteration — pairs well with Gemini
# PROVIDER_GROQ_BASE_URL=https://api.groq.com/openai/v1
# PROVIDER_GROQ_MODEL=llama-3.1-8b-instant
# PROVIDER_GROQ_KEYS=gsk_key1,gsk_key2


# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get key   : https://openrouter.ai/keys
# Free tier : varies per model — look for models with a ":free" suffix
# Best model: meta-llama/llama-3.1-8b-instruct:free (no credits needed)
# Good for  : model variety — access to Claude, GPT, Llama, Mistral on one key
# Note      : HiveMind automatically sends HTTP-Referer and X-Title headers
# PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# PROVIDER_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# PROVIDER_OPENROUTER_KEYS=sk-or-key-here


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get key   : https://platform.openai.com/api-keys
# Free tier : no free tier — requires credits
# Best model: gpt-4o-mini (best price/quality ratio)
# Good for  : highest quality responses, reliable JSON compliance
# PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
# PROVIDER_OPENAI_MODEL=gpt-4o-mini
# PROVIDER_OPENAI_KEYS=sk-key1,sk-key2


# ── Ollama (local) ────────────────────────────────────────────────────────────
# Setup     : https://ollama.com/download — then: ollama pull llama3
# Free tier : fully local, no API keys, no rate limits
# Best model: llama3 (8B), mistral, qwen2.5:7b — depends on your hardware
# Good for  : privacy, offline use, no cost — slower without a GPU
# Note      : use any placeholder for KEYS (e.g. "ollama")
# PROVIDER_OLLAMA_BASE_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_MODEL=llama3
# PROVIDER_OLLAMA_KEYS=ollama


# ── Together AI ───────────────────────────────────────────────────────────────
# Get key   : https://api.together.xyz/settings/api-keys
# Free tier : $1 credit on signup
# Best model: meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# Good for  : open source models, cheap fine-tuned inference
# PROVIDER_TOGETHER_BASE_URL=https://api.together.xyz/v1
# PROVIDER_TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# PROVIDER_TOGETHER_KEYS=together_key1


# ── Tree Settings ─────────────────────────────────────────────────────────────
MAX_DEPTH=6                  # Hard cap on recursion depth (deeper = more agents)
MAX_PARALLEL_AGENTS=8        # Max concurrent LLM calls at once
MIN_COMPLEXITY_TO_SPLIT=3    # 1-10; below this score, agent solves directly
